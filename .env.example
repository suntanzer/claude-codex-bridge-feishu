# ============================================================
# Feishu Bridge Configuration / 飞书 Bridge 配置
# ============================================================
# Copy this file to instances/<name>.env and fill in your values.
# 将此文件复制为 instances/<名称>.env 并填入你的值。
#
# Only FEISHU_APP_ID and FEISHU_APP_SECRET are strictly required.
# 仅 FEISHU_APP_ID 和 FEISHU_APP_SECRET 是严格必需的。
# ============================================================

# ------------------------------------------------------------
# Feishu App Credentials / 飞书应用凭据
# ------------------------------------------------------------
# Get these from https://open.feishu.cn/ -> your app -> Credentials
# 从 https://open.feishu.cn/ -> 你的应用 -> 凭证与基础信息 获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Verification token for webhook validation (recommended)
# Webhook 验证 token（推荐设置）
FEISHU_VERIFICATION_TOKEN=

# Encrypt key for encrypted event payloads (recommended)
# 事件加密密钥（推荐设置）
FEISHU_ENCRYPT_KEY=

# ------------------------------------------------------------
# Callback Server / 回调服务器
# ------------------------------------------------------------
# The bridge starts an HTTP server to receive Feishu event callbacks.
# Bridge 启动 HTTP 服务器接收飞书事件回调。

# Listen address (default: 0.0.0.0)
FEISHU_CALLBACK_LISTEN_HOST=0.0.0.0

# Listen port (default: 8770)
FEISHU_CALLBACK_PORT=8770

# URL path for the callback endpoint (default: /feishu/events/<instance>)
# 回调端点的 URL 路径
FEISHU_CALLBACK_PATH=/feishu/events/bridge

# Public base URL for approval card buttons to work.
# Must be the externally-reachable HTTPS URL (without trailing slash).
# 审批卡片按钮需要的公网 URL（不含尾部斜杠）。
# Example / 示例: https://your-domain.com
FEISHU_PUBLIC_BASE_URL=

# ------------------------------------------------------------
# Message Filtering / 消息过滤
# ------------------------------------------------------------
# Comma-separated allowlists. Empty = allow all.
# 逗号分隔的白名单。空 = 允许全部。

# Only accept messages from these chat IDs
# 仅接受这些会话 ID 的消息
FEISHU_ALLOWED_CHAT_IDS=

# Only accept messages from these user open IDs
# 仅接受这些用户 open_id 的消息
FEISHU_ALLOWED_OPEN_IDS=

# Group chat mode: "mention_only" (default) or "all_messages"
# 群聊模式: "mention_only"（默认，仅@机器人时响应）或 "all_messages"
FEISHU_GROUP_MODE=mention_only

# Send welcome message when user first opens P2P chat (default: false)
# 用户首次打开单聊时发送欢迎消息
FEISHU_SEND_WELCOME_ON_P2P_ENTER=false

# ------------------------------------------------------------
# Bridge Runtime / Bridge 运行时
# ------------------------------------------------------------
# Instance name (used for data dir, tmux session, log prefix)
# 实例名（用于数据目录、tmux 会话名、日志前缀）
BRIDGE_INSTANCE=bridge

# Runner type: claude-sdk | codex | kimi
# Runner 类型
BRIDGE_RUNNER=claude-sdk

# Operational command prefix in chat (default: !bridge)
# 聊天中的运维命令前缀
BRIDGE_COMMAND_PREFIX=!bridge

# Default working directory for the runner
# Runner 的默认工作目录
BRIDGE_DEFAULT_CWD=/path/to/workdir

# Data directory for state persistence (default: ./data/<instance>)
# 状态持久化目录
BRIDGE_DATA_DIR=./data

# Runner execution timeout in minutes (default: 60)
# Runner 执行超时时间（分钟）
BRIDGE_RUNNER_TIMEOUT_MINS=60

# Heartbeat interval — use SECS or MINS (SECS takes priority)
# 心跳间隔 — 使用 SECS 或 MINS（SECS 优先）
BRIDGE_HEARTBEAT_INTERVAL_MINS=5
# BRIDGE_HEARTBEAT_INTERVAL_SECS=30

# Progress message interval in seconds (default: 300)
# 进度消息间隔（秒）
BRIDGE_PROGRESS_MESSAGE_SECS=300

# How many days to keep old requests (default: 7)
# 旧请求保留天数
BRIDGE_REQUEST_RETAIN_DAYS=7

# Runner binary path override (auto-detected by default)
# Runner 二进制路径覆盖（默认自动检测）
# BRIDGE_RUNNER_BIN=

# Shared directory for runner (optional)
# Runner 共享目录（可选）
# BRIDGE_RUNNER_SHARE_DIR=

# ------------------------------------------------------------
# Access Control / 访问控制
# ------------------------------------------------------------
# Comma-separated allowlists. Empty = allow all.
# 逗号分隔白名单。空 = 允许全部。
BRIDGE_ALLOWED_CHANNELS=
BRIDGE_ALLOWED_USERS=

# ------------------------------------------------------------
# Claude SDK Runner / Claude SDK Runner 配置
# ------------------------------------------------------------
# Requires ANTHROPIC_API_KEY in environment.
# 需要环境中有 ANTHROPIC_API_KEY。
BRIDGE_CLAUDE_MODEL=claude-opus-4-6
BRIDGE_CLAUDE_THINKING_MODE=adaptive
BRIDGE_CLAUDE_THINKING_BUDGET_TOKENS=
BRIDGE_CLAUDE_EFFORT=high
BRIDGE_CLAUDE_PERMISSION_MODE=default
BRIDGE_CLAUDE_SYSTEM_PROMPT_FILE=
BRIDGE_CLAUDE_PROJECTS_DIR=
BRIDGE_CLAUDE_ALLOWED_TOOLS=
BRIDGE_CLAUDE_DISALLOWED_TOOLS=

# ------------------------------------------------------------
# Codex Runner / Codex Runner 配置
# ------------------------------------------------------------
# Requires codex CLI: npm i -g @anthropic-ai/codex
# 需要全局安装 codex CLI
BRIDGE_CODEX_BIN=
BRIDGE_CODEX_MODEL=
BRIDGE_CODEX_PROFILE=
BRIDGE_CODEX_REASONING_EFFORT=
BRIDGE_CODEX_FULL_ACCESS=false
BRIDGE_CODEX_SYSTEM_PROMPT_FILE=
BRIDGE_CODEX_HOME_DIR=

# ------------------------------------------------------------
# Kimi Runner / Kimi Runner 配置
# ------------------------------------------------------------
# Requires kimi-cli binary.
# 需要 kimi-cli 二进制文件。
BRIDGE_KIMI_MODEL=
BRIDGE_KIMI_THINKING=
BRIDGE_KIMI_YOLO=false
BRIDGE_KIMI_CONFIG_FILE=
BRIDGE_KIMI_AGENT_FILE=

# ------------------------------------------------------------
# Gemini Readonly Classifier / Gemini 只读分类器
# ------------------------------------------------------------
# Optional second-stage classifier for Claude Bash approval.
# 可选的 Claude Bash 审批二级分类器。
# Disabled by default. When enabled, uncertain Bash commands are
# sent to Gemini to determine if they are readonly.
# 默认关闭。启用后，不确定的 Bash 命令会发给 Gemini 判断是否只读。
BRIDGE_CLAUDE_GEMINI_READONLY_ENABLED=false
BRIDGE_CLAUDE_GEMINI_API_KEY=
BRIDGE_CLAUDE_GEMINI_API_KEYS=
BRIDGE_CLAUDE_GEMINI_MODEL=gemini-2.5-flash-lite
BRIDGE_CLAUDE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Threshold 0-100: confidence required to auto-approve. 100 = most conservative.
# 阈值 0-100：自动通过所需置信度。100 = 最保守。
BRIDGE_CLAUDE_GEMINI_READONLY_THRESHOLD=100
BRIDGE_CLAUDE_GEMINI_TIMEOUT_MS=5000
